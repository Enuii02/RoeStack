extends ../layout

block head
    link(rel="stylesheet", href="/styles/homepage.css")

block content 
    .sorting-buttons 
        a.sort-btn(class= activeSort === "latest" ? "active-latest" : "", href="/") 
            i.fa-regular.fa-clock 
            p Latest 
        a.sort-btn(class= activeSort === "popular" ? "active-popular" : "", href="/?sortby=popular") 
            i.fa-solid.fa-fire  
            p Popular
        a.sort-btn(class= activeSort === "forYou" ? "active-for-you" : "", href="/")
            i.fa-solid.fa-heart 
            p For You

    .posts 
        each post in posts 
            include ../partials/post.pug

    
