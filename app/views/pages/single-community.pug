extends ../layout

block head 
    link(rel="stylesheet", href="/styles/single-community.css")

block content 
    .community-overview 
        .poster-and-picture
            .community-poster 
                p RoeStack
            .community-picture-wrapper
                .community-picture 
        .community-title
            h2= community.name 
        .community-stats 
            if content.session.user.isMod || content.session.user.id == community.createdBy.id
                .empty 
            .right 
                .counter 
                    h3.follower-count= community.amountUsers
                    if community.amountUsers === 1
                        p Follower
                    else    
                        p Followers
            .divider-vertical 
            .left     
                .counter
                    h3= community.amountPosts   
                    if community.amountPosts === 1
                        p Post
                    else    
                        p Posts   

            if content.session.user.isMod || content.session.user.id == community.createdBy.id
                .meatballs
                    .dropdown 
                        button.icon-btn(type="button" onclick="toggleMenu(this)")
                            i.fa-solid.fa-ellipsis-vertical  

                        ul.dropdown-menu 
                            //- JE - Ban and Approve links now point to real routes.
                            //- Active communities: mod can only Ban.
                            //- Pending communities: mod can Approve or Ban.
                            //- Banned communities: mod can only Approve (to restore it).
                            //- All options are only visible to mods.
                            if content.session.user.isMod
                                if community.status === 'active'
                                    li
                                        a(href="/community/ban/" + community.id) Ban

                                if community.status === 'pending'
                                    li
                                        a(href="/community/approve/" + community.id) Approve
                                    li
                                        a(href="/community/ban/" + community.id) Ban

                                if community.status === 'banned'
                                    li
                                        a(href="/community/approve/" + community.id) Approve

                            if content.session.user.id == community.createdBy.id || content.session.user.isMod
                                li 
                                    a(href="#") Modify

        //- JE - Follow button area now handles all three statuses.
        //- Active: shows Follow/Unfollow as normal.
        //- Pending: replaces the follow button with a "Pending Approval" notice so users know the community isn't open yet.
        //- Banned: keeps the existing banned message.
        if community.status === 'active'
            if content.session.user.communities.includes(community.id)
                button(data-id=community.id
                    data-user-id=content.session.user.id).follow-btn.inverse Unfollow
            else
                button(data-id=community.id
                    data-user-id=content.session.user.id).follow-btn Follow
        else if community.status === 'pending'
            h2.description-title This community is pending approval.
        else
            h2.description-title This community has been banned.

        .community-description 
            h2.description-title Module description
            p= community.description
    .divider
        p(style="display: inline-block; margin-right: 4px;") Sort by:
        button.sort-btn(type="button" onclick="toggleMenu(this)")
            p #{activeSort}
            i.fa-solid.fa-angle-down
        
        ul.dropdown-menu 
            li 
                a(href=`${currentPath}?sortby=latest`) Latest

            li 
                a(href=`${currentPath}?sortby=popular`) Popular

            li 
                a(href=`${currentPath}?sortby=oldest`) Oldest
    .line

    .posts 
        each post in posts
            div(style= "margin-bottom: 1rem") 
            include ../partials/post.pug
            div(style= "margin-bottom: 1rem") 

block scripts 
    script(src="/js/profile-page.js" defer)