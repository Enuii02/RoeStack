extends ../layout

block head
    link(rel="stylesheet", href="/styles/comment.css")

block content
    .post-box 
        .top-section
            .left-side
                //a(href="/users/" + user.id)
                .profile-photo
                    if post.user.images && post.user.images.length > 0
                        img(src=`https://owres.org/roestack/${post.user.images[0].url}` alt=post.user.name loading="lazy")
                        
                .user-info
                    .top-line
                        a.username(href="/user/" + post.user.id)= post.user.name
                        span.dot •
                        span.post-time= post.elapsedTime
                    .role Student
            .right-side
                .container 
                    a.community-name(href="/community/" + post.community.id)= post.community.name
                    .category-box
                        - let iconSrc = '/images/icons/comment-solid-full.svg'
                        - if (post.category === 'question') iconSrc = '/images/icons/question-icon.svg'
                        - else if (post.category === 'advice') iconSrc = '/images/icons/comment-medical-solid-full.svg'
                        - else if (post.category === 'survey') iconSrc = '/images/icons/square-poll-horizontal-solid-full.svg'
                        img.category-icon(src=iconSrc alt="Category Icon")
                        span.category-name= post.category 
                        //post.category
                button.icon-btn(type="button" onclick="toggleMenu(this)")
                    img.options(src="/images/icons/three-vertical-dots.svg" alt="Options Icon")
                ul.dropdown-menu 
                    if content.session.user.id == post.user.id
                        li 
                            a(href=`/edit-post/${post.id}`) Edit post 
                        li 
                            a.delete-post(
                                href="#"
                                data-post-id=post.id
                                style="color: red;"
                            ) Delete post
                    if content.session.user.id != post.user.id
                        li
                            a(href="#" style="color: red;") Report post   
        h2.post-title= post.title
        
        if post.imageUrl || post.mapUrl
            .media-card
                if post.imageUrl
                    img(src=post.imageUrl alt="Post Image")
                
                if post.mapUrl
                    iframe(
                        src=post.mapUrl 
                        width="100%" 
                        height="450" 
                        style="border:0;"
                        allowfullscreen 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade"
                    )

        .post-content 
            p= post.content
        .post-footer
            .left-side 
                .interactions
                    button.upvote(
                        data-id=post.id,
                        data-type-id=0,
                        class=post.currentUserVote === 1 ? "active" : ""
                        )
                        img.vote-icon(src="/images/icons/up-vote.svg" alt="Upvote Icon")

                    span.vote-count 
                        span= post.amountVotes

                    button.downvote(
                        data-id=post.id,
                        data-type-id=0,
                        class=post.currentUserVote === -1 ? "active" : ""
                        )
                        img.vote-icon(src="/images/icons/down-vote.svg" alt="Downvote Icon")
                .answers
                    img.answer-icon(src="/images/icons/chat-left.svg" alt="Answer Icon")
                    span.answer-count= post.answersCount + " answers"
        .form-answer
            input.main-answer(type="text" placeholder="Write your comment here...")
            button.answer-btn(disabled) Post Your Answer
        .divider
            p.sort-label Sort by:  
            button.sort-btn(type="button" onclick="toggleMenu(this)")
                p Best
                i.fa-solid.fa-angle-down
            
            ul.dropdown-menu 
                li 
                    a(href="#" data-sort="best") Best 

                li 
                    a(href="#" data-sort="latest") Latest

                li 
                    a(href="#" data-sort="oldest") Oldest
        .line
        include ../partials/comment
        .answers-section
            each comment in comments
                +commentItem(comment, content)
block scripts
    script(src="/js/comment.js" defer)