.demo-banner#demo-banner(hidden)
    .demo-banner-content
        button.demo-banner-close(type="button" aria-label="Close" onclick="hideDemoBanner()") &times;
        h2.demo-banner-title Demo Mode
        p.demo-banner-text#demo-banner-message This action is disabled on the public demo.
        p.demo-banner-subtext Try out the rest of the app, or check the source on GitHub.
        a.demo-banner-link(href="https://github.com/Enuii02/RoeStack/tree/main" target="_blank" rel="noopener") View the project on GitHub
