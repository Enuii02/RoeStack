.demo-banner#demo-banner(hidden)
    .demo-banner-content
        button.demo-banner-close(type="button" aria-label="Close" onclick="document.getElementById('demo-banner').setAttribute('hidden', '')") &times;
        h2.demo-banner-title Demo Mode
        p.demo-banner-text This is a public demo of RoeStack. Creating, editing, and deleting posts and comments is disabled for safety and moderation reasons.
        p.demo-banner-subtext Try out the rest of the app, or check the source on GitHub.
        a.demo-banner-link(href="https://github.com/Enuii02/RoeStack/tree/main" target="_blank" rel="noopener") View the project on GitHub
