html 
    head    
        title RoeStack

        link(rel="stylesheet", href="/styles/main.css")
        link(rel="stylesheet", href="/styles/layout.css")
        link(rel="stylesheet", href="/styles/post.css")
        link(rel="stylesheet", href="/styles/explore-card.css")
        link(rel="stylesheet", href="/styles/explore-page.css")
        link(rel="stylesheet", href="/styles/demo-banner.css")
        link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
        block head
    body
        include ./partials/demo-banner.pug
        script(src="/js/demo-banner.js")
        include ./partials/header.pug

        .layout 
            include ./partials/left-sidebar.pug

            main.content 
                block content 
            
            include ./partials/right-sidebar.pug
        script(src="/js/sidebar.js" defer)
        script(src="/js/ProfilePage.js" defer)
        script(src="/js/Vote.js" defer)
        script(src="/js/Community.js" defer)
        script(src="/js/register.js")
        script(src="/js/search.js" type="module" defer)
        script(src="/js/post.js" type="module" defer)
        block scripts
        

