extends layout
block content
    - console.log(data)
    .main-content 
    h1 All posts 
    table(border=1)
        for item in data 
            h2 #{"User " + item.username + " created '" + item.title + "' at " + item.creation_timestamp}
            h4(style="margin-bottom:40px") #{"Content: " + item.content}
            
